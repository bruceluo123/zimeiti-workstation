# ============================================================
# 自媒体工作站 — 环境变量配置
# 1. 复制此文件为 .env.local，填入真实值
# 2. Vercel 部署时在项目设置 → Environment Variables 中填写
# ============================================================

# ── A. 云同步（Upstash KV）────────────────────────────────
# 建议在 https://console.upstash.com 新建独立数据库（免费 tier 够用）
# 如不填，自动回退到共享 KV（与招聘系统共用，数据隔离靠 zmt: 命名空间）
NEXT_PUBLIC_ZMT_KV_URL=https://YOUR-DATABASE.upstash.io
NEXT_PUBLIC_ZMT_KV_TOKEN=YOUR_REST_TOKEN

# ── B. 灵感库数据（aihot.virxact.com）────────────────────
# 无需 API Key，匿名公开访问。
# 此变量仅用于本地覆盖 API 地址（一般不需修改）
# ZMT_AIHOT_BASE=https://aihot.virxact.com

# ── C. 素材工厂（AI 图像生成）───────────────────────────
# DashScope（阿里通义万象）— 推荐，国内无网络问题
# 前往 https://dashscope.aliyun.com 获取 API Key
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx

# OpenAI DALL·E — 备用（需代理）
# OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxx
